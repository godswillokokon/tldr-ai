# tldr-ai-be — copy to `.env` and fill in secrets. Never commit `.env`.
# This file is not loaded by the server; only `.env` (root and tldr-ai-be/) are read at startup.

# Server
PORT=8080

# HTTP client IP (set TRUST_PROXY=1 behind a reverse proxy you trust to set X-Forwarded-For)
TRUST_PROXY=0

# CORS: e.g. https://app.example.com or * (empty = no CORS headers)
CORS_ALLOW_ORIGIN=

# Anthropic (create tldr-ai-be/.env from this file; set a real key from console.anthropic.com)
# Use a single = . Wrong: ANTHROPIC_API_KEY==... (second = becomes part of the value and causes 401)
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-sonnet-4-6

# Rate limit (0 RPS = disabled)
RATE_LIMIT_RPS=0
RATE_LIMIT_MAX_IPS=10000

# Usage / budget (0 = no cap in that dimension; 5 = $5 monthly estimated spend cap)
USAGE_BUDGET_USD=5
USAGE_PER_CALL_USD=0.01
USAGE_MAX_CALLS=0

# If set, POST /api/admin/usage-reset is enabled and requires X-Usage-Reset-Secret
USAGE_RESET_SECRET=
